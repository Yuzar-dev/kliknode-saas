# ========================================
# APPLICATION
# ========================================
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# ========================================
# DATABASE
# ========================================
DATABASE_URL=postgresql://postgres:password@localhost:5432/vcard_saas

# ========================================
# JWT AUTHENTICATION
# ========================================
JWT_SECRET=your-super-secret-jwt-key-change-me-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-me-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ========================================
# STRIPE (PAYMENT)
# ========================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# ========================================
# SENDGRID (EMAIL)
# ========================================
SENDGRID_API_KEY=SG.your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@vcard.io
SENDGRID_FROM_NAME=V-Card

# ========================================
# AWS S3 / CLOUDFLARE R2 (FILE STORAGE)
# ========================================
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=eu-west-3
AWS_S3_BUCKET=vcard-uploads
AWS_S3_ENDPOINT=https://s3.eu-west-3.amazonaws.com

# Pour CloudFlare R2, décommenter et adapter :
# AWS_S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# ========================================
# RATE LIMITING
# ========================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_SIGNUP_MAX=3

# ========================================
# FILE UPLOADS
# ========================================
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp

# ========================================
# ADMIN (SUPER ADMIN CREDENTIALS)
# ========================================
ADMIN_EMAIL=admin@vcard.io
ADMIN_PASSWORD=ChangeMe123!

# ========================================
# MAINTENANCE MODE
# ========================================
MAINTENANCE_MODE=false

# ========================================
# LOGGING
# ========================================
LOG_LEVEL=info
